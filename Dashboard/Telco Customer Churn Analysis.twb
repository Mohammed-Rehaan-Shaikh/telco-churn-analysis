      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0zuf7w80yacxej1aocr581ykw8y8].[avg:tenure:qk]&quot;' value='Average Tenure' />
          <alias key='&quot;[federated.0zuf7w80yacxej1aocr581ykw8y8].[avg:total_charges:qk]&quot;' value='Total Charges' />
          <alias key='&quot;[federated.0zuf7w80yacxej1aocr581ykw8y8].[sum:monthly_charges:qk]&quot;' value='Monthly Revenue' />
          <alias key='&quot;[federated.0zuf7w80yacxej1aocr581ykw8y8].[usr:Calculation_0860380002734080:qk]&quot;' value='Total Customers' />
        </aliases>
      </column>
      <column caption='Tenure Group' datatype='string' name='[Calculation_0141850971541504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0-12 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;13-24 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;25-48 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 72 THEN &quot;49-72 Months&quot;&#13;&#10;ELSE &quot;72+ Months&quot;&#13;&#10;END' />
      </column>
      <column caption='Customers' datatype='integer' name='[Calculation_0860380002734080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Churned Customers' datatype='integer' name='[Calculation_0860380004179970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Retained Customers' datatype='integer' name='[Calculation_0952739432230912]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;No&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_0952739432468481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;Yes&quot; THEN 1 ELSE 0 END) / COUNTD([customer_id])' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_0952739432652802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;No&quot; THEN 1 ELSE 0 END) / COUNTD([customer_id])' />
      </column>
      <column caption='Monthly Revenue at Risk' datatype='real' name='[Calculation_0952739432943619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;Yes&quot; THEN [monthly_charges] ELSE 0 END)' />
      </column>
      <column caption='Retained Monthly Revenue' datatype='real' name='[Calculation_0952739433025540]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;No&quot; THEN [monthly_charges] ELSE 0 END)' />
      </column>
      <column caption='Revenue at Risk %' datatype='real' name='[Calculation_0952739433078789]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [churn] = &quot;Yes&quot; THEN [monthly_charges] ELSE 0 END) / SUM([monthly_charges])' />
      </column>
      <column caption='Box' datatype='string' name='[Calculation_0952739444617224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='Average Monthly Charges ' datatype='real' name='[Monthly Charges (copy)_0952739433328646]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([monthly_charges])' />
      </column>
